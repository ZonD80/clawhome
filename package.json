{
  "name": "clawhome",
  "version": "1.0.0",
  "description": "A secure home to your Clawbot, so you don't need to buy separate mac",
  "main": "dist-electron/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:clawvm": "bash scripts/build-claw-vm.sh",
    "electron:dev": "electron-vite dev",
    "electron:build": "electron-vite build",
    "electron:preview": "electron-vite preview"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.0.0",
    "typescript": "^5.6.0",
    "vite": "^5.0.0"
  },
  "build": {
    "directories": {
      "output": "release/${version}"
    },
    "extraResources": [
      { "from": "dist-electron/resources/ClawVMManager", "to": "ClawVMManager" },
      { "from": "dist-electron/resources/ClawVMRunner", "to": "ClawVMRunner" },
      { "from": "dist-electron/resources/ClawVM", "to": "ClawVM" }
    ],
    "mac": {
      "icon": "icon.png",
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "hardenedRuntime": true
    },
    "win": {
      "icon": "icon.png"
    },
    "linux": {
      "icon": "icon.png"
    }
  }
}